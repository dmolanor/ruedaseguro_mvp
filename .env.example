# ============================================================
# RuedaSeguro — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# Supabase Edge Function secrets are set via:
#   supabase secrets set KEY=value
# and are NOT stored in this file.
# ============================================================

# ---- Supabase -----------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

SUPABASE_API_KEY=
SUPABASE_PROJECT_ID=
# ---- Admin Portal (Next.js) ---------------------------------
# Same values as above; Next.js reads these from .env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- WhatsApp Business Cloud API ----------------------------
# Used by send-otp and verify-otp Edge Functions.
# Set as Supabase secrets (not in .env):
#   supabase secrets set WHATSAPP_TOKEN=your-permanent-token
#   supabase secrets set WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
#
# How to get these:
#   1. developers.facebook.com → Create App → Business → WhatsApp
#   2. WhatsApp > Getting Started → copy Phone Number ID
#   3. WhatsApp > Configuration → generate a Permanent Access Token
#      (System Users in Business Manager → assign WhatsApp permission)
#
# Message template required (Meta Business Manager):
#   Name:     otp_verification
#   Category: Authentication
#   Language: Spanish (es)
#   Body:     Tu código de verificación RuedaSeguro es: {{1}}. Válido por 10 minutos.
#
WHATSAPP_TOKEN=your-whatsapp-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
VERIFICATION_PACKAGE_NAME=
VERIFICATION_HASH=

# ---- OTP Dev Bypass -----------------------------------------
# Skips WhatsApp entirely during local development.
# send-otp: prints OTP to Edge Function logs instead of sending WhatsApp
# verify-otp: accepts "000000" as a master bypass code
#
# Enable:   supabase secrets set SUPABASE_OTP_DEV_BYPASS=true
# Disable:  supabase secrets set SUPABASE_OTP_DEV_BYPASS=false
# View OTP: supabase functions logs send-otp --scroll
#
# NEVER enable in production.
SUPABASE_OTP_DEV_BYPASS=false

# ---- BCV Rate Edge Function ---------------------------------
# No additional secrets needed — uses SUPABASE_SERVICE_ROLE_KEY above.

# ---- SMS / MessageBird -------------------------------------
# Used by Supabase Phone Auth provider (Authentication → Providers → Phone).
# Set directly in Supabase Dashboard, not as an Edge Function secret.
MESSAGE_BIRD_API_KEY=your-messagebird-api-key

# ---- Cloudflare Turnstile -----------------------------------
# SITE KEY  → public, also goes in mobile/.env.example (Flutter dart-define)
# SECRET KEY → server-side only; set as Supabase secret:
#   supabase secrets set TURNSTILE_SECRET_KEY=your-secret-key
# Supabase validates the token server-side using the secret key automatically
# when CAPTCHA is enabled in Authentication → Settings.
TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key
TURNSTILE_SECRET_KEY=your-cloudflare-turnstile-secret-key
