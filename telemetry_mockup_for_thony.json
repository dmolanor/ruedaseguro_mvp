{
  "_description": "RuedaSeguro — Telemetry mockup payload for IoT/backend integration (Phase 1.5)",
  "_notes": [
    "Each 'event' represents a 15-minute buffer window flushed after a detected impact.",
    "Samples are ordered oldest-first, newest-last within the window.",
    "recorded_at is Unix timestamp in milliseconds (UTC).",
    "g_force is scalar magnitude (m/s² normalized to g). Impact threshold TBD with Thony.",
    "lat/lon are WGS-84 decimal degrees. Altitude in meters. Speed in km/h.",
    "Transport: Supabase Realtime (MQTT deferred to Phase 2).",
    "Table: telemetry_events"
  ],

  "schema": {
    "telemetry_event": {
      "policy_id": "uuid — FK to policies table",
      "rider_id": "uuid — FK to auth.users",
      "device_id": "string — phone hardware ID or IoT node ID",
      "triggered_by": "string — 'impact' | 'periodic' | 'manual'",
      "peak_g_force": "float — highest g_force in the window",
      "samples": "array<TelemetrySample>",
      "uploaded_at": "ISO-8601 UTC"
    },
    "TelemetrySample": {
      "recorded_at": "integer — Unix ms UTC",
      "g_force": "float | null — scalar g (1g ≈ 9.81 m/s²)",
      "latitude": "float | null — WGS-84",
      "longitude": "float | null — WGS-84",
      "altitude_m": "float | null — meters above sea level",
      "speed_kmh": "float | null"
    }
  },

