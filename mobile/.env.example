# ============================================================
# RuedaSeguro Mobile — Flutter dart-define variables
# ============================================================
# These are the ONLY keys the Flutter app needs.
# All values here are PUBLIC (safe to embed in the app binary).
#
# Usage:
#   flutter run \
#     --dart-define=SUPABASE_URL=... \
#     --dart-define=SUPABASE_ANON_KEY=... \
#     --dart-define=TURNSTILE_SITE_KEY=...
#
# Secret keys (service role, MessageBird, Turnstile secret) live in
# the root .env.example and are set as Supabase secrets — never here.
# ============================================================

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Cloudflare Turnstile — SITE key only (public).
# The SECRET key stays in Supabase: supabase secrets set TURNSTILE_SECRET_KEY=...
TURNSTILE_SITE_KEY=0x4AAAAAACD9_23456789
